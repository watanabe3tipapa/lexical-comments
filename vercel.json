{
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" }
  ],
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs22.x",
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
